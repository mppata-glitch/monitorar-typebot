{
  "annotations": [
    {
      "kind": "AnnotationQuery",
      "spec": {
        "builtIn": true,
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "query": {
          "datasource": {
            "name": "-- Grafana --"
          },
          "group": "grafana",
          "kind": "DataQuery",
          "spec": {},
          "version": "v0"
        }
      }
    }
  ],
  "cursorSync": "Off",
  "editable": true,
  "elements": {
    "total-requests": {
      "kind": "Panel",
      "spec": {
        "title": "Total HTTP Requests",
        "type": "stat",
        "pluginVersion": "11.0.0",
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "sum(traefik_entrypoint_requests_total)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [{ "color": "green", "value": null }]
            }
          }
        },
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto"
        }
      }
    },
    "rps-service": {
      "kind": "Panel",
      "spec": {
        "title": "Requests per Second by Service",
        "type": "timeseries",
        "pluginVersion": "11.0.0",
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "sum(irate(traefik_service_requests_total[5m])) by (service_name)",
            "legendFormat": "{{service_name}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "reqps"
          }
        }
      }
    }
  },
  "layout": {
    "kind": "GridLayout",
    "spec": {
      "items": [
        {
          "x": 0,
          "y": 0,
          "w": 6,
          "h": 5,
          "element": "total-requests"
        },
        {
          "x": 6,
          "y": 0,
          "w": 18,
          "h": 10,
          "element": "rps-service"
        }
      ]
    }
  },
  "links": [],
  "liveNow": false,
  "preferences": {},
  "preload": false,
  "tags": ["traefik"],
  "timeSettings": {
    "autoRefresh": "5s",
    "fiscalYearStartMonth": 0,
    "from": "now-1h",
    "hideTimepicker": false,
    "timezone": "browser",
    "to": "now"
  },
  "title": "Traefik Dashboard (V3 Scenes)",
  "variables": []
}
